{
  "version": "1.0",
  "ai": {
    "provider": "minimax",
    "model": "minimax/minimax-m2.5:free",
    "base_url": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.0,
    "languages": [
      "en", "zh"
    ]
  },
  "sources": {
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "rss": [
      {
        "name": "量子位",
        "url": "https://wechat2rss.xlab.app/feed/7131b577c61365cb47e81000738c10d872685908.xml",
        "enabled": true,
        "category": ""
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "artificial",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "ChatGPTCoding",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "technology",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "ChatGPT",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        }
      ],
      "users": [],
      "fetch_comments": 10
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter":
    {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5,
      "actor_id": "altimis~scweet",
      "apify_token_env": "APIFY_TOKEN"
    }
  },
  "filtering": {
    "ai_score_threshold": 1.0,
    "time_window_hours": 24
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.163.com",
    "smtp_port": 465,
    "imap_server": "imap.163.com",
    "imap_port": 993,
    "email_address": "yuehanui@163.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "webhook": null
}
